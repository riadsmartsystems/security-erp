# ── MariaDB ──────────────────────────────────────────────────────────────────
# Пароль root-користувача MariaDB (використовується bench для створення БД)
MYSQL_ROOT_PASSWORD=changeme_root

# ── ERPNext Site ─────────────────────────────────────────────────────────────
# Ім'я сайту Frappe (доменне або erp.localhost для локальної розробки)
SITE_NAME=erp.localhost

# Пароль адміністратора ERPNext UI (логін: Administrator)
ADMIN_PASSWORD=changeme_admin

# ── Traefik / Domain ─────────────────────────────────────────────────────────
# Публічний домен (для Traefik-маршрутизації)
# Для локальної розробки залишити erp.localhost
DOMAIN=erp.localhost

# ── Security API (services/security-api/) ────────────────────────────────────
# JWT secret (мінімум 32 символи, генерується: openssl rand -hex 32)
SECRET_KEY=changeme_secret_key_min_32_chars

# Frappe API-ключ (bench --site erp.localhost new-api-key --user Administrator)
FRAPPE_API_KEY=changeme_api_key
FRAPPE_API_SECRET=changeme_api_secret

# Пароль адміністратора Frappe (той самий, що ADMIN_PASSWORD вище)
FRAPPE_PASSWORD=changeme_admin

# URL Frappe всередині Docker-мережі (не змінювати для стандартного compose)
FRAPPE_URL=http://erpnext-backend:8000

# Redis (не змінювати для стандартного compose)
REDIS_URL=redis://redis:6379/0

# Anthropic API key для AI-функцій (опційно)
ANTHROPIC_API_KEY=
