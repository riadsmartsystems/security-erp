{
  "name": "WF-02: Прострочена КП",
  "nodes": [
    {
      "id": "schedule-trigger",
      "name": "Daily Check",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [250, 300],
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 24
            }
          ]
        }
      }
    },
    {
      "id": "http-request",
      "name": "Get Overdue Quotations",
      "type": "n8n-nodes-base.httpRequest",
      "position": [450, 300],
      "parameters": {
        "url": "http://erpnext-backend:8000/api/resource/Quotation",
        "method": "GET",
        "authentication": "genericCredentialType",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "token {{ $credentials.frappeApiKey }}:{{ $credentials.frappeApiSecret }}"
            }
          ]
        },
        "queryParameters": {
          "parameters": [
            {
              "name": "filters",
              "value": "[[\"Quotation\",\"status\",\"=\",\"Open\"],[\"Quotation\",\"valid_till\",\"<\",\"{{ $now.format('yyyy-MM-dd') }}\"]]"
            },
            {
              "name": "fields",
              "value": "[\"name\",\"customer_name\",\"valid_till\",\"grand_total\"]"
            }
          ]
        }
      }
    },
    {
      "id": "telegram",
      "name": "Send Telegram Alert",
      "type": "n8n-nodes-base.telegram",
      "position": [650, 300],
      "parameters": {
        "chatId": "{{ $env.NOTIFICATION_TELEGRAM_CHAT_IDS }}",
        "text": "⚠️ Прострочена КП:\n\n📋 {{ $json.data.name }}\n👤 {{ $json.data.customer_name }}\n💰 {{ $json.data.grand_total }} грн\n📅 Термін: {{ $json.data.valid_till }}\n\nПотрібно зв'язатися з клієнтом!",
        "additionalFields": {}
      }
    }
  ],
  "connections": {
    "Daily Check": {
      "main": [
        [
          {
            "node": "Get Overdue Quotations",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Get Overdue Quotations": {
      "main": [
        [
          {
            "node": "Send Telegram Alert",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": true,
  "settings": {
    "executionOrder": "v1"
  }
}
