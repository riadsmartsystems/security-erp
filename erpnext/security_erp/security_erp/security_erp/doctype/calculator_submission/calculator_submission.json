{
    "name": "Calculator Submission",
    "module": "Security ERP",
    "doctype": "DocType",
    "document_type": "Document",
    "engine": "InnoDB",
    "autoname": "format:CALC-{#####}",
    "fields": [
        {"fieldname": "section_input", "fieldtype": "Section Break", "label": "Input Parameters"},
        {"fieldname": "object_type", "fieldtype": "Select", "label": "Object Type", "options": "CCTV Analog\nCCTV IP\nAccess Control\nAlarm\nNetwork\nMixed", "reqd": 1, "in_list_view": 1},
        {"fieldname": "area_m2", "fieldtype": "Float", "label": "Area (m²)", "reqd": 1},
        {"fieldname": "cameras_count", "fieldtype": "Int", "label": "Cameras Count", "reqd": 1},
        {"fieldname": "archive_days", "fieldtype": "Int", "label": "Archive Days", "reqd": 1},
        {"fieldname": "column_break_input", "fieldtype": "Column Break"},
        {"fieldname": "contact_name", "fieldtype": "Data", "label": "Contact Name", "reqd": 1},
        {"fieldname": "contact_phone", "fieldtype": "Data", "label": "Contact Phone", "reqd": 1},
        {"fieldname": "contact_email", "fieldtype": "Data", "label": "Contact Email"},
        {"fieldname": "section_result", "fieldtype": "Section Break", "label": "Result"},
        {"fieldname": "estimated_total", "fieldtype": "Currency", "label": "Estimated Total", "read_only": 1},
        {"fieldname": "matched_scenario", "fieldtype": "Link", "label": "Matched Scenario", "options": "Security Scenario", "read_only": 1},
        {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "новий\nоброблено\nспам", "default": "новий", "reqd": 1, "in_list_view": 1},
        {"fieldname": "column_break_result", "fieldtype": "Column Break"},
        {"fieldname": "source_ip", "fieldtype": "Data", "label": "Source IP", "read_only": 1, "permlevel": 1},
        {"fieldname": "captcha_passed", "fieldtype": "Check", "label": "Captcha Passed", "default": "0"},
        {"fieldname": "section_lead", "fieldtype": "Section Break", "label": "Lead", "collapsible": 1},
        {"fieldname": "lead", "fieldtype": "Link", "label": "Lead", "options": "Lead"}
    ],
    "permissions": [
        {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "permlevel": 0},
        {"role": "System Manager", "read": 1, "write": 1, "permlevel": 1},
        {"role": "Service Manager", "read": 1, "write": 1, "create": 1, "permlevel": 0},
        {"role": "Service Manager", "read": 1, "permlevel": 1},
        {"role": "Sales Manager", "read": 1, "permlevel": 0},
        {"role": "Sales Manager", "read": 1, "permlevel": 1}
    ],
    "title_field": "contact_name",
    "search_fields": "contact_name,contact_phone,contact_email",
    "sort_field": "modified",
    "sort_order": "DESC",
    "track_changes": 0
}
