{
    "name": "Media Asset",
    "module": "Security ERP",
    "doctype": "DocType",
    "document_type": "Document",
    "engine": "InnoDB",
    "istable": 0,
    "autoname": "hash",
    "fields": [
        {"fieldname": "client_uuid", "fieldtype": "Data", "label": "Client UUID", "in_list_view": 1},
        {"fieldname": "drive_file_id", "fieldtype": "Data", "label": "Drive File ID"},
        {"fieldname": "media_type", "fieldtype": "Select", "label": "Media Type", "options": "\nphoto\nvideo\naudio", "in_list_view": 1},
        {"fieldname": "column_break_1", "fieldtype": "Column Break"},
        {"fieldname": "tag", "fieldtype": "Select", "label": "Tag", "options": "\nbefore\nafter\nsmm\ninspection\nplan", "in_list_view": 1},
        {"fieldname": "ai_allowed", "fieldtype": "Check", "label": "AI Allowed", "default": "0"},
        {"fieldname": "captured_at", "fieldtype": "Datetime", "label": "Captured At"},
        {"fieldname": "captured_by", "fieldtype": "Link", "label": "Captured By", "options": "User"},
        {"fieldname": "section_transcription", "fieldtype": "Section Break", "label": "Transcription"},
        {"fieldname": "transcription", "fieldtype": "Long Text", "label": "Transcription"},
        {"fieldname": "transcription_status", "fieldtype": "Select", "label": "Transcription Status", "options": "pending\nprocessing\ndone\nfailed", "default": "pending"},
        {"fieldname": "column_break_2", "fieldtype": "Column Break"},
        {"fieldname": "parent_doctype", "fieldtype": "Link", "label": "Parent DocType", "options": "DocType"},
        {"fieldname": "parent_name", "fieldtype": "Dynamic Link", "label": "Parent Name", "options": "parent_doctype"},
        {"fieldname": "section_sync", "fieldtype": "Section Break", "label": "Sync Metadata"},
        {"fieldname": "riad_version", "fieldtype": "Int", "label": "RIAD Version", "default": "0", "read_only": 1},
        {"fieldname": "riad_deleted", "fieldtype": "Check", "label": "Deleted", "default": "0", "read_only": 1},
        {"fieldname": "riad_deleted_at", "fieldtype": "Datetime", "label": "Deleted At", "read_only": 1}
    ],
    "permissions": [
        {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
        {"role": "Service Manager", "read": 1, "write": 1, "create": 1}
    ],
    "title_field": "media_type",
    "sort_field": "modified",
    "sort_order": "DESC",
    "track_changes": 0
}
