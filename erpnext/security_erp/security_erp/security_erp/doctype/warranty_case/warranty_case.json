{
    "name": "Warranty Case",
    "module": "Security ERP",
    "doctype": "DocType",
    "document_type": "Document",
    "engine": "InnoDB",
    "fields": [
        {"fieldname": "case_number", "fieldtype": "Data", "label": "Case Number", "read_only": 1, "unique": 1, "in_list_view": 1},
        {"fieldname": "ticket", "fieldtype": "Link", "label": "Ticket", "options": "Service Ticket"},
        {"fieldname": "equipment", "fieldtype": "Link", "label": "Equipment", "options": "Equipment", "reqd": 1, "in_list_view": 1},
        {"fieldname": "customer", "fieldtype": "Link", "label": "Customer", "options": "Customer", "reqd": 1},
        {"fieldname": "column_break_main", "fieldtype": "Column Break"},
        {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Open\nVerified\nApproved\nRejected\nRepair\nReplacement\nClosed", "default": "Open", "in_list_view": 1},
        {"fieldname": "manufacturer_claim", "fieldtype": "Check", "label": "Manufacturer Claim", "default": 0},
        {"fieldname": "section_description", "fieldtype": "Section Break", "label": "Description"},
        {"fieldname": "description", "fieldtype": "Text Editor", "label": "Description", "reqd": 1},
        {"fieldname": "resolution", "fieldtype": "Text Editor", "label": "Resolution"}
    ],
    "permissions": [
        {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
        {"role": "Service Manager", "read": 1, "write": 1, "create": 1},
        {"role": "Engineer", "read": 1}
    ],
    "autoname": "naming_series:",
    "naming_series": {"field": "case_number", "options": "WRN-.######"},
    "title_field": "case_number",
    "search_fields": "case_number,customer,equipment",
    "sort_field": "modified",
    "sort_order": "DESC",
    "track_changes": 1
}
