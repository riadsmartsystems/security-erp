{
    "name": "Contract",
    "module": "Security ERP",
    "doctype": "DocType",
    "document_type": "Document",
    "engine": "InnoDB",
    "is_submittable": 0,
    "issingle": 0,
    "istable": 0,
    "fields": [
        {"fieldname": "contract_number", "fieldtype": "Data", "label": "Contract Number", "read_only": 1, "unique": 1, "in_list_view": 1},
        {"fieldname": "customer", "fieldtype": "Link", "label": "Customer", "options": "Customer", "reqd": 1, "in_list_view": 1},
        {"fieldname": "customer_name", "fieldtype": "Data", "label": "Customer Name", "fetch_from": "customer.customer_name", "read_only": 1},
        {"fieldname": "contract_type", "fieldtype": "Select", "label": "Contract Type", "options": "Service\nInstallation\nMaintenance\nMixed", "reqd": 1, "in_list_view": 1},
        {"fieldname": "start_date", "fieldtype": "Date", "label": "Start Date", "reqd": 1},
        {"fieldname": "end_date", "fieldtype": "Date", "label": "End Date", "reqd": 1},
        {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Draft\nActive\nSuspended\nExpired\nTerminated", "default": "Draft", "in_list_view": 1},
        {"fieldname": "column_break_1", "fieldtype": "Column Break"},
        {"fieldname": "contract_value", "fieldtype": "Currency", "label": "Contract Value", "options": "Company:company:default_currency"},
        {"fieldname": "currency", "fieldtype": "Link", "label": "Currency", "options": "Currency", "default": "UAH"},
        {"fieldname": "payment_terms", "fieldtype": "Small Text", "label": "Payment Terms"},
        {"fieldname": "sla_tab", "fieldtype": "Section Break", "label": "SLA"},
        {"fieldname": "sla_template", "fieldtype": "Link", "label": "SLA Template", "options": "Service Level Agreement"},
        {"fieldname": "response_time_hours", "fieldtype": "Float", "label": "Response Time (Hours)"},
        {"fieldname": "resolution_time_hours", "fieldtype": "Float", "label": "Resolution Time (Hours)"},
        {"fieldname": "section_break_objects", "fieldtype": "Section Break", "label": "Service Objects"},
        {"fieldname": "objects", "fieldtype": "Table", "label": "Contract Objects", "options": "Contract Object"},
        {"fieldname": "section_break_notes", "fieldtype": "Section Break", "label": "Notes"},
        {"fieldname": "notes", "fieldtype": "Text Editor", "label": "Notes"},
        {"fieldname": "quotation", "fieldtype": "Link", "label": "Quotation", "options": "Quotation"},
        {"fieldname": "amended_from", "fieldtype": "Link", "label": "Amended From", "options": "Contract", "read_only": 1, "no_copy": 1}
    ],
    "permissions": [
        {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
        {"role": "Sales Manager", "read": 1, "write": 1, "create": 1},
        {"role": "Service Manager", "read": 1, "write": 1},
        {"role": "Project Manager", "read": 1}
    ],
    "autoname": "naming_series:",
    "naming_series": {"field": "contract_number", "options": "CTR-.YYYY.-.####"},
    "title_field": "customer_name",
    "search_fields": "customer,customer_name,contract_number",
    "sort_field": "modified",
    "sort_order": "DESC",
    "track_changes": 1
}
