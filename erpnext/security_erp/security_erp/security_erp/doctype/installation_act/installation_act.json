{
    "name": "Installation Act",
    "module": "Security ERP",
    "doctype": "DocType",
    "document_type": "Document",
    "engine": "InnoDB",
    "is_submittable": 1,
    "fields": [
        {"fieldname": "act_number", "fieldtype": "Data", "label": "Act Number", "read_only": 1, "unique": 1, "in_list_view": 1},
        {"fieldname": "project", "fieldtype": "Link", "label": "Project", "options": "Project", "reqd": 1, "in_list_view": 1},
        {"fieldname": "customer", "fieldtype": "Link", "label": "Customer", "options": "Customer", "reqd": 1, "in_list_view": 1},
        {"fieldname": "customer_name", "fieldtype": "Data", "label": "Customer Name", "fetch_from": "customer.customer_name", "read_only": 1},
        {"fieldname": "column_break_1", "fieldtype": "Column Break"},
        {"fieldname": "act_date", "fieldtype": "Date", "label": "Date", "reqd": 1, "default": "Today"},
        {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Draft\nPending Approval\nApproved\nRejected\nCompleted", "default": "Draft", "in_list_view": 1},
        {"fieldname": "object_address", "fieldtype": "Small Text", "label": "Object Address"},
        {"fieldname": "section_break_items", "fieldtype": "Section Break", "label": "Installed Equipment"},
        {"fieldname": "items", "fieldtype": "Table", "label": "Installed Items", "options": "Installation Act Item"},
        {"fieldname": "section_break_summary", "fieldtype": "Section Break", "label": "Summary"},
        {"fieldname": "total_amount", "fieldtype": "Currency", "label": "Total Amount", "read_only": 1},
        {"fieldname": "labor_hours", "fieldtype": "Float", "label": "Labor Hours"},
        {"fieldname": "column_break_summary", "fieldtype": "Column Break"},
        {"fieldname": "notes", "fieldtype": "Text Editor", "label": "Notes"},
        {"fieldname": "customer_signature", "fieldtype": "Attach Image", "label": "Customer Signature"},
        {"fieldname": "amended_from", "fieldtype": "Link", "label": "Amended From", "options": "Installation Act", "read_only": 1, "no_copy": 1}
    ],
    "permissions": [
        {"role": "System Manager", "read": 1, "write": 1, "create": 1, "submit": 1, "cancel": 1},
        {"role": "Project Manager", "read": 1, "write": 1, "create": 1, "submit": 1},
        {"role": "Service Manager", "read": 1, "write": 1},
        {"role": "Engineer", "read": 1, "write": 1, "create": 1}
    ],
    "autoname": "naming_series:",
    "naming_series": {"field": "act_number", "options": "ACT-.YYYY.-.####"},
    "title_field": "customer_name",
    "search_fields": "customer,customer_name,act_number,project",
    "sort_field": "modified",
    "sort_order": "DESC",
    "track_changes": 1
}
