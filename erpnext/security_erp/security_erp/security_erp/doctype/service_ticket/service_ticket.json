{
    "name": "Service Ticket",
    "module": "Security ERP",
    "doctype": "DocType",
    "document_type": "Document",
    "engine": "InnoDB",
    "is_submittable": 0,
    "fields": [
        {"fieldname": "ticket_number", "fieldtype": "Data", "label": "Ticket Number", "read_only": 1, "unique": 1, "in_list_view": 1},
        {"fieldname": "customer", "fieldtype": "Link", "label": "Customer", "options": "Customer", "reqd": 1, "in_list_view": 1},
        {"fieldname": "customer_name", "fieldtype": "Data", "label": "Customer Name", "fetch_from": "customer.customer_name", "read_only": 1},
        {"fieldname": "security_object", "fieldtype": "Link", "label": "Security Object", "options": "Security Object"},
        {"fieldname": "contract", "fieldtype": "Link", "label": "Contract", "options": "Contract"},
        {"fieldname": "column_break_main", "fieldtype": "Column Break"},
        {"fieldname": "ticket_type", "fieldtype": "Select", "label": "Type", "options": "Incident\nService Request\nPreventive Maintenance\nInstallation\nWarranty\nInspection\nEmergency", "default": "Incident", "reqd": 1, "in_list_view": 1},
        {"fieldname": "priority", "fieldtype": "Select", "label": "Priority", "options": "Critical\nHigh\nMedium\nLow", "default": "Medium", "reqd": 1, "in_list_view": 1},
        {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "New\nTriage\nAssigned\nAccepted\nOn Route\nWorking\nWaiting Parts\nResolved\nClosed\nCancelled", "default": "New", "in_list_view": 1},
        {"fieldname": "assigned_engineer", "fieldtype": "Link", "label": "Assigned Engineer", "options": "User"},
        {"fieldname": "section_description", "fieldtype": "Section Break", "label": "Description"},
        {"fieldname": "title", "fieldtype": "Data", "label": "Title", "reqd": 1},
        {"fieldname": "description", "fieldtype": "Text Editor", "label": "Description"},
        {"fieldname": "tab_sla", "fieldtype": "Section Break", "label": "SLA", "collapsible": 1},
        {"fieldname": "sla_response_due", "fieldtype": "Datetime", "label": "Response Due", "read_only": 1},
        {"fieldname": "sla_arrival_due", "fieldtype": "Datetime", "label": "Arrival Due", "read_only": 1},
        {"fieldname": "sla_resolution_due", "fieldtype": "Datetime", "label": "Resolution Due", "read_only": 1},
        {"fieldname": "column_break_sla", "fieldtype": "Column Break"},
        {"fieldname": "sla_response_breached", "fieldtype": "Check", "label": "Response Breached", "read_only": 1, "default": 0},
        {"fieldname": "sla_arrival_breached", "fieldtype": "Check", "label": "Arrival Breached", "read_only": 1, "default": 0},
        {"fieldname": "sla_resolution_breached", "fieldtype": "Check", "label": "Resolution Breached", "read_only": 1, "default": 0},
        {"fieldname": "sla_paused_at", "fieldtype": "Datetime", "label": "SLA Paused At", "read_only": 1, "hidden": 1},
        {"fieldname": "sla_pause_minutes", "fieldtype": "Int", "label": "SLA Pause Minutes", "read_only": 1, "hidden": 1},
        {"fieldname": "tab_sla_events", "fieldtype": "Section Break", "label": "SLA Events", "collapsible": 1},
        {"fieldname": "sla_events", "fieldtype": "Table", "label": "SLA Events", "options": "SLA Event"},
        {"fieldname": "section_timestamps", "fieldtype": "Section Break", "label": "Timestamps", "collapsible": 1},
        {"fieldname": "resolved_at", "fieldtype": "Datetime", "label": "Resolved At", "read_only": 1},
        {"fieldname": "closed_at", "fieldtype": "Datetime", "label": "Closed At", "read_only": 1},
        {"fieldname": "is_active", "fieldtype": "Check", "label": "Active", "default": 1, "hidden": 1}
    ],
    "permissions": [
        {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
        {"role": "Service Manager", "read": 1, "write": 1, "create": 1},
        {"role": "Project Manager", "read": 1, "write": 1},
        {"role": "Engineer", "read": 1, "write": 1}
    ],
    "autoname": "naming_series:",
    "naming_series": {"field": "ticket_number", "options": "TKT-.######"},
    "title_field": "title",
    "search_fields": "ticket_number,customer,customer_name,title",
    "sort_field": "modified",
    "sort_order": "DESC",
    "track_changes": 1
}
