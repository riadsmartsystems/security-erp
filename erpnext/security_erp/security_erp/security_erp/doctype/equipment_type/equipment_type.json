        {"fieldname": "type_name", "fieldtype": "Data", "label": "Type Name", "reqd": 1, "in_list_view": 1},
        {"fieldname": "type_code", "fieldtype": "Data", "label": "Type Code", "reqd": 1, "unique": 1, "in_list_view": 1},
        {"fieldname": "category", "fieldtype": "Select", "label": "Category", "options": "CCTV\nNetwork\nACS\nAlarm\nServer\nUPS\nOther", "reqd": 1, "in_list_view": 1},
        {"fieldname": "parent_type", "fieldtype": "Link", "label": "Parent Type", "options": "Equipment Type"},
