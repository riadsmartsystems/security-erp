{
    "name": "AI Estimate",
    "module": "Security ERP",
    "doctype": "DocType",
    "document_type": "Document",
    "engine": "InnoDB",
    "controller": "security_erp.security_erp.doctype.ai_estimate.estimate.Estimate",
    "fields": [
        {"fieldname": "estimate_number", "fieldtype": "Data", "label": "Estimate Number", "read_only": 1, "unique": 1, "in_list_view": 1},
        {"fieldname": "customer", "fieldtype": "Link", "label": "Customer", "options": "Customer", "reqd": 1, "in_list_view": 1},
        {"fieldname": "customer_name", "fieldtype": "Data", "label": "Customer Name", "fetch_from": "customer.customer_name", "read_only": 1},
        {"fieldname": "security_type", "fieldtype": "Select", "label": "Security Type", "options": "\nCCTV\nAccess Control\nAlarm\nNetwork\nMixed", "reqd": 1, "in_list_view": 1},
        {"fieldname": "column_break_1", "fieldtype": "Column Break"},
        {"fieldname": "estimate_date", "fieldtype": "Date", "label": "Date", "reqd": 1, "default": "Today"},
        {"fieldname": "validity_days", "fieldtype": "Int", "label": "Validity (Days)", "default": 30},
        {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Draft\nSent\nApproved\nRejected\nConverted to Quotation\nExpired\nAI Draft", "default": "Draft", "in_list_view": 1},
        {"fieldname": "origin", "fieldtype": "Select", "label": "Origin", "options": "manual\nai\nimported", "default": "manual", "in_list_view": 1},
        {"fieldname": "variant", "fieldtype": "Data", "label": "Variant"},
        {"fieldname": "section_break_object", "fieldtype": "Section Break", "label": "Object Details"},
        {"fieldname": "object_name", "fieldtype": "Data", "label": "Object Name"},
        {"fieldname": "object_address", "fieldtype": "Small Text", "label": "Address"},
        {"fieldname": "column_break_object", "fieldtype": "Column Break"},
        {"fieldname": "object_area_sqm", "fieldtype": "Float", "label": "Area (sq.m)"},
        {"fieldname": "object_type", "fieldtype": "Select", "label": "Object Type", "options": "\nShop\nOffice\nWarehouse\nFactory\nSchool\nResidential\nOther"},
        {"fieldname": "section_break_items", "fieldtype": "Section Break", "label": "Estimate Items"},
        {"fieldname": "items", "fieldtype": "Table", "label": "Items", "options": "AI Estimate Item"},
        {"fieldname": "section_break_totals", "fieldtype": "Section Break", "label": "Totals"},
        {"fieldname": "total_amount", "fieldtype": "Currency", "label": "Total Amount", "read_only": 1},
        {"fieldname": "discount_percent", "fieldtype": "Percent", "label": "Discount %"},
        {"fieldname": "column_break_totals", "fieldtype": "Column Break"},
        {"fieldname": "discount_amount", "fieldtype": "Currency", "label": "Discount Amount", "read_only": 1},
        {"fieldname": "grand_total", "fieldtype": "Currency", "label": "Grand Total", "read_only": 1},
        {"fieldname": "section_break_costs", "fieldtype": "Section Break", "label": "Cost Analysis"},
        {"fieldname": "total_cost", "fieldtype": "Currency", "label": "Total Cost", "read_only": 1, "permlevel": 1},
        {"fieldname": "total_margin", "fieldtype": "Currency", "label": "Total Margin", "read_only": 1, "permlevel": 1},
        {"fieldname": "column_break_review", "fieldtype": "Column Break"},
        {"fieldname": "reviewed_by", "fieldtype": "Link", "label": "Reviewed By", "options": "User", "read_only": 1, "permlevel": 1},
        {"fieldname": "reviewed_at", "fieldtype": "Datetime", "label": "Reviewed At", "read_only": 1, "permlevel": 1},
        {"fieldname": "lead", "fieldtype": "Link", "label": "Ліід", "options": "Lead"},
        {"fieldname": "section_break_tz", "fieldtype": "Section Break", "label": "Technical Specification"},
        {"fieldname": "tz_text", "fieldtype": "Long Text", "label": "Technical Specification (TZ)"},
        {"fieldname": "section_break_notes", "fieldtype": "Section Break", "label": "Notes"},
        {"fieldname": "notes", "fieldtype": "Text Editor", "label": "Notes"},
        {"fieldname": "quotation", "fieldtype": "Link", "label": "Quotation", "options": "Quotation", "read_only": 1}
    ],
    "permissions": [
        {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
        {"role": "System Manager", "read": 1, "write": 1, "permlevel": 1},
        {"role": "Sales Manager", "read": 1, "write": 1, "create": 1},
        {"role": "Sales Manager", "read": 1, "write": 1, "permlevel": 1},
        {"role": "Service Manager", "read": 1}
    ],
    "autoname": "naming_series:",
    "naming_series": {"field": "estimate_number", "options": "EST-.YYYY.-.####"},
    "title_field": "customer_name",
    "search_fields": "customer,customer_name,estimate_number",
    "sort_field": "modified",
    "sort_order": "DESC",
    "track_changes": 1
}
