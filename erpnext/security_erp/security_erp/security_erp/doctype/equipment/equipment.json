{
    "name": "Equipment",
    "module": "Security ERP",
    "doctype": "DocType",
    "document_type": "Document",
    "engine": "InnoDB",
    "fields": [
        {"fieldname": "equipment_code", "fieldtype": "Data", "label": "Equipment Code", "read_only": 1, "unique": 1, "in_list_view": 1},
        {"fieldname": "security_object", "fieldtype": "Link", "label": "Security Object", "options": "Security Object", "reqd": 1, "in_list_view": 1},
        {"fieldname": "room", "fieldtype": "Link", "label": "Room", "options": "Object Room"},
        {"fieldname": "equipment_type", "fieldtype": "Link", "label": "Equipment Type", "options": "Equipment Type", "reqd": 1, "in_list_view": 1},
        {"fieldname": "vendor", "fieldtype": "Link", "label": "Vendor", "options": "Vendor", "reqd": 1},
        {"fieldname": "column_break_main", "fieldtype": "Column Break"},
        {"fieldname": "model", "fieldtype": "Data", "label": "Model", "reqd": 1, "in_list_view": 1},
        {"fieldname": "serial_number", "fieldtype": "Data", "label": "Serial Number", "unique": 1},
        {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Planned\nIn Stock\nReserved\nInstalled\nActive\nService\nRepair\nReplaced\nRetired", "default": "Planned", "in_list_view": 1},
        {"fieldname": "tab_technical", "fieldtype": "Section Break", "label": "Technical Details", "collapsible": 1},
        {"fieldname": "firmware_version", "fieldtype": "Data", "label": "Firmware Version"},
        {"fieldname": "ip_address", "fieldtype": "Data", "label": "IP Address"},
        {"fieldname": "mac_address", "fieldtype": "Data", "label": "MAC Address"},
        {"fieldname": "column_break_tech", "fieldtype": "Column Break"},
        {"fieldname": "install_date", "fieldtype": "Date", "label": "Install Date"},
        {"fieldname": "warranty_end_date", "fieldtype": "Date", "label": "Warranty End Date"},
        {"fieldname": "lifecycle_project", "fieldtype": "Link", "label": "Lifecycle Project", "options": "Project"},
        {"fieldname": "section_notes", "fieldtype": "Section Break", "label": "Notes"},
        {"fieldname": "notes", "fieldtype": "Text Editor", "label": "Notes"},
        {"fieldname": "is_active", "fieldtype": "Check", "label": "Active", "default": 1, "hidden": 1}
    ],
    "permissions": [
        {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
        {"role": "Service Manager", "read": 1, "write": 1, "create": 1},
        {"role": "Project Manager", "read": 1, "write": 1, "create": 1},
        {"role": "Engineer", "read": 1}
    ],
    "autoname": "naming_series:",
    "naming_series": {"field": "equipment_code", "options": "CI-.######"},
    "title_field": "model",
    "search_fields": "equipment_code,model,serial_number,security_object",
    "sort_field": "modified",
    "sort_order": "DESC",
    "track_changes": 1
}
