{
    "name": "Visit",
    "module": "Security ERP",
    "doctype": "DocType",
    "document_type": "Document",
    "engine": "InnoDB",
    "istable": 0,
    "autoname": "field:client_uuid",
    "fields": [
        {"fieldname": "client_uuid", "fieldtype": "Data", "label": "Client UUID",
         "unique": 1, "reqd": 1, "in_list_view": 0, "read_only": 0},
        {"fieldname": "riad_version", "fieldtype": "Int", "label": "Riad Version",
         "default": "0", "read_only": 1},
        {"fieldname": "riad_deleted", "fieldtype": "Check", "label": "Deleted",
         "default": "0"},
        {"fieldname": "riad_deleted_at", "fieldtype": "Datetime",
         "label": "Deleted At", "read_only": 1},
        {"fieldname": "section_identity", "fieldtype": "Section Break",
         "label": "Identity"},
        {"fieldname": "service_ticket", "fieldtype": "Link",
         "label": "Service Ticket", "options": "Service Ticket"},
        {"fieldname": "engineer", "fieldtype": "Link", "label": "Engineer",
         "options": "User", "reqd": 1, "in_list_view": 1},
        {"fieldname": "status", "fieldtype": "Select", "label": "Status",
         "options": "Planned\nAccepted\nOn Route\nArrived\nWorking\nCompleted",
         "default": "Planned", "in_list_view": 1},
        {"fieldname": "visit_type", "fieldtype": "Select", "label": "Visit Type",
         "options": "Inspection\nInstallation\nService\nDismantling",
         "default": "Service"},
        {"fieldname": "column_break_time", "fieldtype": "Column Break"},
        {"fieldname": "planned_start", "fieldtype": "Datetime",
         "label": "Planned Start"},
        {"fieldname": "actual_start", "fieldtype": "Datetime",
         "label": "Actual Start", "read_only": 1},
        {"fieldname": "actual_finish", "fieldtype": "Datetime",
         "label": "Actual Finish", "read_only": 1},
        {"fieldname": "section_gps", "fieldtype": "Section Break",
         "label": "GPS", "collapsible": 1},
        {"fieldname": "gps_checkin_lat", "fieldtype": "Float",
         "label": "Check-in Lat", "read_only": 1},
        {"fieldname": "gps_checkin_lon", "fieldtype": "Float",
         "label": "Check-in Lon", "read_only": 1},
        {"fieldname": "gps_checkout_lat", "fieldtype": "Float",
         "label": "Check-out Lat", "read_only": 1},
        {"fieldname": "gps_checkout_lon", "fieldtype": "Float",
         "label": "Check-out Lon", "read_only": 1},
        {"fieldname": "travel_minutes", "fieldtype": "Int",
         "label": "Travel Minutes"},
        {"fieldname": "work_minutes", "fieldtype": "Int",
         "label": "Work Minutes", "read_only": 1},
        {"fieldname": "section_summary", "fieldtype": "Section Break",
         "label": "Summary"},
        {"fieldname": "summary", "fieldtype": "Small Text", "label": "Summary"},
        {"fieldname": "notes", "fieldtype": "Text Editor", "label": "Notes"},
        {"fieldname": "customer_signature", "fieldtype": "Attach Image",
         "label": "Customer Signature"},
        {"fieldname": "section_photos", "fieldtype": "Section Break",
         "label": "Photos"},
        {"fieldname": "photos", "fieldtype": "Table", "label": "Photos",
         "options": "Visit Photo"},
        {"fieldname": "section_materials", "fieldtype": "Section Break",
         "label": "Materials"},
        {"fieldname": "materials", "fieldtype": "Table", "label": "Materials",
         "options": "Visit Material"}
    ],
    "permissions": [
        {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
        {"role": "Service Manager", "read": 1, "write": 1, "create": 1},
        {"role": "Engineer", "read": 1, "write": 1, "create": 1}
    ],
    "title_field": "engineer",
    "sort_field": "modified",
    "sort_order": "DESC",
    "track_changes": 0
}
