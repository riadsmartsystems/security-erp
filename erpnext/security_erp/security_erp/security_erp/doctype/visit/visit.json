{
    "name": "Visit",
    "module": "Security ERP",
    "doctype": "DocType",
    "istable": 1,
    "fields": [
        {"fieldname": "visit_number", "fieldtype": "Data", "label": "Visit Number", "read_only": 1, "unique": 1, "in_list_view": 1},
        {"fieldname": "engineer", "fieldtype": "Link", "label": "Engineer", "options": "User", "reqd": 1, "in_list_view": 1},
        {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Planned\nAccepted\nOn Route\nArrived\nWorking\nCompleted", "default": "Planned", "in_list_view": 1},
        {"fieldname": "planned_start", "fieldtype": "Datetime", "label": "Planned Start"},
        {"fieldname": "actual_start", "fieldtype": "Datetime", "label": "Actual Start", "read_only": 1},
        {"fieldname": "actual_finish", "fieldtype": "Datetime", "label": "Actual Finish", "read_only": 1},
        {"fieldname": "column_break_gps", "fieldtype": "Column Break"},
        {"fieldname": "gps_checkin_lat", "fieldtype": "Float", "label": "Check-in Lat", "read_only": 1},
        {"fieldname": "gps_checkin_lon", "fieldtype": "Float", "label": "Check-in Lon", "read_only": 1},
        {"fieldname": "gps_checkout_lat", "fieldtype": "Float", "label": "Check-out Lat", "read_only": 1},
        {"fieldname": "gps_checkout_lon", "fieldtype": "Float", "label": "Check-out Lon", "read_only": 1},
        {"fieldname": "travel_minutes", "fieldtype": "Int", "label": "Travel Minutes"},
        {"fieldname": "work_minutes", "fieldtype": "Int", "label": "Work Minutes", "read_only": 1},
        {"fieldname": "section_photos", "fieldtype": "Section Break", "label": "Photos"},
        {"fieldname": "photos", "fieldtype": "Table", "label": "Photos", "options": "Visit Photo"},
        {"fieldname": "section_materials", "fieldtype": "Section Break", "label": "Materials"},
        {"fieldname": "materials", "fieldtype": "Table", "label": "Materials", "options": "Visit Material"},
        {"fieldname": "section_notes", "fieldtype": "Section Break", "label": "Notes"},
        {"fieldname": "notes", "fieldtype": "Text Editor", "label": "Notes"},
        {"fieldname": "customer_signature", "fieldtype": "Attach Image", "label": "Customer Signature"}
    ],
    "permissions": [
        {"role": "System Manager", "read": 1, "write": 1, "create": 1},
        {"role": "Service Manager", "read": 1, "write": 1, "create": 1},
        {"role": "Engineer", "read": 1, "write": 1, "create": 1}
    ],
    "autoname": "naming_series:",
    "naming_series": {"field": "visit_number", "options": "VIS-.######"}
}
