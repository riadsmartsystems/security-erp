{
    "name": "Security Scenario",
    "module": "Security ERP",
    "doctype": "DocType",
    "document_type": "Document",
    "engine": "InnoDB",
    "fields": [
        {"fieldname": "scenario_name", "fieldtype": "Data", "label": "Scenario Name", "reqd": 1, "in_list_view": 1},
        {"fieldname": "security_type", "fieldtype": "Select", "label": "Security Type", "options": "CCTV Analog\nCCTV IP\nAccess Control\nAlarm\nNetwork", "reqd": 1, "in_list_view": 1},
        {"fieldname": "description", "fieldtype": "Small Text", "label": "Description"},
        {"fieldname": "is_active", "fieldtype": "Check", "label": "Is Active", "default": "1"},
        {"fieldname": "section_break_items", "fieldtype": "Section Break", "label": "Items"},
        {"fieldname": "items", "fieldtype": "Table", "label": "Items", "options": "Security Scenario Item"}
    ],
    "permissions": [
        {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
        {"role": "Service Manager", "read": 1, "write": 1, "create": 1},
        {"role": "Sales Manager", "read": 1}
    ],
    "title_field": "scenario_name",
    "search_fields": "scenario_name,security_type",
    "sort_field": "modified",
    "sort_order": "DESC",
    "track_changes": 1
}
